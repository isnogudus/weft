# weft -- Docker Compose examples.
#
# 1) Point weft at LDAP infrastructure you already run (the default `weft`
#    service, no profile needed). Configure ./weft.toml with your real
#    ldap_url, base_dn, admin_dn and directory flavor (see
#    weft.toml.example) -- it's already gitignored, so your real settings
#    never land in the repo. Then:
#
#      docker compose up --build weft
#
#    The container joins the external "frontend" and "matrix" networks below
#    -- rename them to whatever your reverse proxy / LDAP stack actually use
#    (check with `docker network ls`; Compose prefixes network names with the
#    project directory by default unless that project sets `name:` itself).
#    Once weft shares that network, it reaches your LDAP server by its
#    compose service name (e.g. ldap_url = "ldap://openldap:389" in
#    ./weft.toml) via Docker's built-in DNS -- no depends_on needed (Compose
#    can't depend_on a service from another project anyway) and none wanted:
#    weft dials LDAP lazily per request, not at startup, so it doesn't matter
#    which of the two containers comes up first.
#    No host port is published by default -- reach weft through the reverse
#    proxy on the frontend network, or uncomment `ports:` for direct
#    http://localhost:8080 access while testing.
#
# 2) Self-contained demo stack, no external infra needed (bundled OpenLDAP):
#
#      docker compose --profile demo up --build openldap weft-demo
#
#    -> http://localhost:8080, setup wizard rootpw "adminpw", login admin/adminpw
#    Talks plain LDAP internally and serves plain HTTP -- evaluation only.
#
# 3) In-memory dev mode, no LDAP server at all:
#
#      docker compose --profile dev up --build weft-dev
#
#    -> http://localhost:8080, login admin/rootpw. Data lives only in the
#    container's memory and is gone on restart.
#
# Profiles only ADD services, they never exclude the default ones -- pass the
# explicit service names as shown above so e.g. the demo command doesn't also
# try (and fail) to start the default `weft` against your own infra.

services:
  # --- 1) Your own LDAP infrastructure (default) ---
  weft:
    build:
      context: .
    networks:
      - frontend
      - matrix
    # ports:
    #   - "8080:8080"   # uncomment for direct localhost access without a reverse proxy
    volumes:
      - ./weft.toml:/etc/weft/weft.toml:ro
    command: ["-config", "/etc/weft/weft.toml"]

  # --- 2) Self-contained demo stack (opt-in via --profile demo) ---
  openldap:
    profiles: ["demo"]
    image: osixia/openldap:1.5.0
    # platform: linux/amd64   # uncomment if your host arch has no native image
    # Works around a runc/seccomp bug ("error adding SSB flag to seccomp
    # filter: ... API level: 1") seen on some Docker Desktop/Colima setups,
    # where the host kernel's seccomp API level is misdetected. It breaks any
    # exec into the container (including the healthcheck below), not just
    # openldap. Root fix: update Docker Desktop/Colima to a runc >= 1.1.6.
    # Safe here since this stack is local-only.
    security_opt:
      - seccomp:unconfined
    environment:
      LDAP_ORGANISATION: "Example Org"
      LDAP_DOMAIN: "example.org"          # -> base dc=example,dc=org
      LDAP_ADMIN_PASSWORD: "adminpw"      # rootdn cn=admin,dc=example,dc=org
      LDAP_TLS: "false"
    volumes:
      - ldap-data:/var/lib/ldap
      - ldap-config:/etc/ldap/slapd.d
    healthcheck:
      test: ["CMD-SHELL", "ldapsearch -x -H ldap://127.0.0.1 -b dc=example,dc=org -s base >/dev/null"]
      interval: 5s
      timeout: 3s
      retries: 12

  weft-demo:
    profiles: ["demo"]
    build:
      context: .
    depends_on:
      openldap:
        condition: service_healthy
    ports:
      - "8080:8080"
    # Core settings via env; the mounted TOML adds what env cannot express
    # (the [[user_attr]] tables). Env has precedence over the file.
    environment:
      WEFT_DIRECTORY: openldap
      WEFT_LDAP_URL: ldap://openldap:389
      WEFT_BASE_DN: dc=example,dc=org
      WEFT_ADMIN_DN: cn=admin,dc=example,dc=org
      WEFT_TLS_MODE: plain
      WEFT_ALLOW_PLAIN_BIND: "true"   # internal compose network only
      WEFT_COOKIE_SECURE: "false"     # plain-HTTP demo access
    volumes:
      - ./contrib/docker/weft.toml:/etc/weft/weft.toml:ro
    command: ["-config", "/etc/weft/weft.toml"]

  # --- 3) In-memory dev directory (opt-in via --profile dev) ---
  weft-dev:
    profiles: ["dev"]
    build:
      context: .
    ports:
      - "8080:8080"
    command: ["-dev"]

networks:
  frontend:
    external: true
    # name: frontend   # set explicitly if `docker network ls` shows a different name
  matrix:
    external: true
    # name: matrix

volumes:
  ldap-data:
  ldap-config:
