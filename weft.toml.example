# weft configuration. Copy to weft.toml and adjust. Every value except
# ldap_url and base_dn has a sensible default; the minimal config is just those
# two plus a TLS mode.

# --- Core (required) ---
ldap_url = "ldaps://ldap.example.org:636"
base_dn  = "dc=example,dc=org"

# Server flavor: "ldapd" (OpenBSD ldapd(8), default) or "openldap".
# Same wire protocol; the flavor selects server-specific behaviour (OpenLDAP
# renames uids atomically via ModifyDN). See README for the OpenLDAP ACLs.
# directory = "ldapd"

# User naming/identifier attribute: "uid" (default) or "cn". This becomes the
# RDN of every user entry (<user_id_attr>=<value>,ou=people,<base>), the login
# name, and the value tracked in group memberUid. Set "cn" for directories
# that name user entries by cn= instead of uid= -- e.g. some Matrix/Synapse
# LDAP setups map cn to the login attribute (matrix-synapse-ldap3's
# `attributes.uid` config key). The value keeps the same strict charset
# either way: Synapse's own localpart rules reject spaces/uppercase/non-ASCII,
# so cn must hold a short login handle here (e.g. "jdoe"), not a full display
# name -- givenName/sn/displayName remain free text for that.
# user_id_attr = "uid"

# For a LOCAL setup (weft and ldapd on the same host) the simplest option is the
# Unix socket -- no TLS, no certificates:
#   ldap_url = "ldapi:///var/run/ldapi"
# With an ldapi:// url, tls_mode / ca_cert_file / insecure_skip_verify /
# allow_plain_bind are all IGNORED (the socket is local, secured by filesystem
# permissions). The matching ldapd.conf needs:  listen on "/var/run/ldapi"

# --- Transport security to the LDAP server (network transports only) ---
# ldaps   : implicit TLS (recommended; use with an ldaps:// url)
# starttls: ldap:// then StartTLS
# plain   : NO TLS -- requires allow_plain_bind=true, dev only
tls_mode = "ldaps"
# ca_cert_file = "/etc/ssl/ldap-ca.pem"   # preferred for a privately-signed server cert
# insecure_skip_verify = false            # skip cert verification (self-signed); logs a warning.
#                                         # Also available as the -insecure flag. Prefer ca_cert_file.
# allow_plain_bind     = false            # dev only

# --- Admin identity ---
# You log in by typing admin_uid as the username; the session then binds as the
# admin DN, which MUST equal ldapd's rootdn. weft prints the resolved DN at
# startup and shows it in the setup wizard.
admin_uid = "admin"
# admin_dn: the bind DN. Leave unset to derive uid=<admin_uid>,ou=people,<base>.
# Set it when your rootdn has a different shape, e.g.:
# admin_dn = "cn=admin,dc=example,dc=org"
#
# allow_admin: set false for a self-service-only deployment -- the admin uid is
# rejected at login, so no admin/management UI is reachable. (The rootdn still
# works out-of-band and for the one-time setup wizard.) The active mode is
# printed at startup ("admin login: ENABLED/DISABLED").
# allow_admin = true

# --- Directory layout (defaults shown) ---
# people_ou      = "people"
# groups_ou      = "groups"
# primary_group  = "users"      # shared default primary group

# --- POSIX defaults ---
# uid_min = 10000
# uid_max = 59999
# gid_min = 10000
# gid_max = 59999
# home_template = "/home/{uid}"
# default_shell = "/bin/ksh"

# --- Mail attribute mapping ---
# mail_attr       = "mail"      # primary address attribute
# mail_alias_attr = ""          # empty -> aliases stored as extra "mail" values

# --- Extra user attributes ---
# Each [[user_attr]] adds a single-valued attribute to the user form, detail
# view and import. `attr` is the LDAP attribute name; the labels are shown in
# the UI (fallback: the other language, then the attribute name).
#
# The set below covers what a twenty-search/Matrix user-directory sync reads
# from the directory. All of these are MAY attributes of the inetOrgPerson
# chain, so they work without schema changes:
#
# [[user_attr]]
# attr     = "telephoneNumber"
# label_de = "Telefon"
# label_en = "Phone"
#
# [[user_attr]]
# attr     = "ou"               # Dienststelle / department
# label_de = "Dienststelle"
# label_en = "Department"
#
# [[user_attr]]
# attr     = "departmentNumber" # Einheit / Fachbereich
# label_de = "Einheit / Fachbereich"
# label_en = "Unit / section"
#
# [[user_attr]]
# attr     = "o"
# label_de = "Landes- / Bundesbehörde"
# label_en = "Organization"
#
# [[user_attr]]
# attr     = "st"
# label_de = "Bundesland"
# label_en = "State"
#
# [[user_attr]]
# attr     = "l"
# label_de = "Dienstort"
# label_en = "Locality"
#
# [[user_attr]]
# attr     = "title"
# label_de = "Dienstfunktion"
# label_en = "Title"
#
# [[user_attr]]
# attr     = "labeledURI"
# label_de = "URL"
# label_en = "URL"
#
# Attributes OUTSIDE the inetOrgPerson chain (e.g. "c"/countryName, or
# site-specific ones like a radio call name) additionally need an auxiliary
# objectClass whose schema is loaded on the server, listed in:
# user_extra_classes = ["policePerson"]
#
# [[user_attr]]
# attr     = "c"                # requires an auxiliary class -- NOT valid on plain inetOrgPerson
# label_de = "Land"
# label_en = "Country"
#
# [[user_attr]]
# attr     = "destinationIndicator"  # "HideExternally" opts a user out of external indexing
# label_de = "Externe Sichtbarkeit"
# label_en = "External visibility"

# Adds a "generate test users" option to the bulk import wizard: given a
# first/last name and a count, it creates a block of synthetic users
# (e.g. anna_m000, anna_m001, ...) with randomised values for whichever of
# the extra attributes above are configured (st, l, o, ou, departmentNumber,
# title, telephoneNumber). For load-testing/demo data only -- off by default,
# since bulk account creation deserves an explicit opt-in even though it
# grants no capability an admin doesn't already have via the regular import.
# enable_test_user_generator = false

# --- Password hashing (bcrypt -> {CRYPT}) ---
# bcrypt_cost         = 12
# max_password_length = 72       # bcrypt truncates beyond 72 bytes

# --- Sandbox ---
# Every non-dev run uses privilege separation (a monitor/worker process split;
# see README). When STARTED AS ROOT the worker chroot(2)s and drops privileges to
# `user`/`group`; on OpenBSD it also applies pledge(2)/unveil(2). The
# chroot/privdrop is skipped automatically when not started as root. Set
# sandbox=false to keep the process split but turn off chroot/pledge/unveil.
# sandbox = true             # master switch for chroot/privdrop/pledge/unveil
# chroot  = "/var/empty"     # chroot dir when root; "" disables chroot (keeps privdrop)
# user    = "_weft"          # drop to this user when root; "" keeps the current uid
# group   = ""               # "" = the user's primary group
#
# NOTE: a chroot to /var/empty removes access to DNS and to Unix sockets. For a
# chrooted setup, use ldaps://<IP-address> (not a hostname) with a ca_cert_file.
# With an ldapi:// url weft skips the chroot automatically (the socket is outside
# it); privilege drop and pledge/unveil still apply. With a hostname, use an IP
# address or set chroot = "".

# --- Logging ---
# stderr (default): one line per request/event to stderr, for the supervisor to
#   capture (journald, runit/svlogd, FreeBSD daemon(8) -S, ...).
# syslog: write to the local syslog. Under privsep the (non-chrooted) monitor
#   owns the syslog connection and reconnects across syslogd restarts, and
#   forwards the chrooted worker's log lines to it. Idiomatic for OpenBSD rc.d.
# log = "stderr"
# syslog_tag = "weft"

# --- HTTP server ---
listen_addr = "127.0.0.1:8080"   # put relayd/httpd in front for TLS
# tls_cert_file = "/etc/ssl/weft.crt"   # optional standalone TLS instead of a proxy
# tls_key_file  = "/etc/ssl/private/weft.key"
# session_timeout = "30m"     # idle timeout: the server expires a session after
#                             # this long without a request (sliding), and the
#                             # SPA switches to the login view when it expires.
cookie_secure = true             # set false ONLY for local plain-http dev
